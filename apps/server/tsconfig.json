{
  "compilerOptions": {
    "composite": true,
    "strict": true,
    "module": "CommonJS",
    "moduleResolution": "node",
    "target": "ES2020",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "src",
    "baseUrl": "../../",
    "paths": {
      "@repo/*": ["packages/*"]
    }
  },
  "include": ["src/**/*", "GameManager.ts"],
  "references": [
    { "path": "../../packages/shared" },
    { "path": "../../packages/game-engine" }
  ]
}